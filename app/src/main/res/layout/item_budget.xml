<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_card"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/iv_budget_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/outline_article_person_24"
                android:background="@drawable/bg_circle_white"
                android:backgroundTint="@color/gray_light"
                app:tint="@color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tv_budget_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ăn uống"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main" />

                <TextView
                    android:id="@+id/tv_budget_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Còn lại: 2.000.000 ₫"
                    android:textSize="12sp"
                    android:textColor="@color/text_sub" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_budget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:trackThickness="8dp"
            app:trackCornerRadius="4dp"
            app:indicatorColor="@color/primary"
            app:trackColor="#F1F5F9"
            android:progress="0" />

        <TextView
            android:id="@+id/tv_budget_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 / 2.000.000 ₫"
            android:textSize="13sp"
            android:textAlignment="viewEnd"
            android:textColor="@color/text_sub" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
