<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cyan"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginBottom="16dp"
            android:text="Chọn danh mục"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>
    <!-- Filter Toggle -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_filter_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:layout_marginBottom="16dp"
        android:layout_margin="20dp">
        <Button
            android:id="@+id/btn_filter_expense"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chi tiêu"
            android:textSize="12sp"
            android:textColor="@color/income_green"
            android:backgroundTint="@color/xanhlanhat"/>
        <Button
            android:id="@+id/btn_filter_income"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thu nhập"
            android:textSize="12sp"
            android:textColor="@color/expense_color"
            android:backgroundTint="@color/dohongnhat"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_categories"
        android:layout_width="match_parent"
        android:layout_height="300dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_custom_category"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/cyan"
        android:text="+ Thêm danh mục mới"
        android:textColor="@color/white"
        app:cornerRadius="12dp" />

</LinearLayout>